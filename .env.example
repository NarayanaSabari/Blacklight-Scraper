NODE_ENV=production
PORT=3001
LOG_LEVEL=info

# Auto queue checker (enabled in production)
QUEUE_CHECK_INTERVAL_MS=30000
QUEUE_CHECK_STARTUP_DELAY_MS=5000

# Default location for per-platform search URLs.
# The backend no longer drives location-specific scraping (only role-based);
# each scraper instance falls back to this. Override per-instance to scope
# a machine to a tighter region (e.g. "California" or "New York, NY").
SCRAPER_DEFAULT_LOCATION=United States

# LinkedIn CDP
CHROME_PATH=/usr/bin/google-chrome
CDP_PORT=9222

# ── Observability ──────────────────────────────────────────────────────────
# Telemetry is proxied through the existing Blacklight scraper API, so
# no extra URL or API key is required — the scraper auto-picks up
# blacklight.apiUrl + blacklight.apiKey from credentials.json.
#
# Only set these if you want to override the defaults:

# Unique instance label (defaults to os.hostname()).
INSTANCE_ID=

# "daemon" for always-on machines (Pi, VPS) — alerts fire if silent > 5 min.
# "interactive" (default) for laptops — no offline alerts.
SCRAPER_MODE=interactive

# Override the telemetry target / key (defaults to blacklight.apiUrl + apiKey).
# Handy for testing against a local backend.
TELEMETRY_URL=
TELEMETRY_KEY=

# Push cadence tuning.
METRICS_PUSH_INTERVAL_MS=30000
LOKI_PUSH_INTERVAL_MS=5000
LOKI_PUSH_BATCH_MAX=200
