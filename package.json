{
  "name": "unified-job-scraper",
  "version": "2.0.0",
  "description": "Unified job scraper API for multiple platforms (Monster, Dice, TechFetch, LinkedIn, Glassdoor, Indeed)",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:prod": "node --max-old-space-size=4096 server.js",
    "creds:clean": "node scripts/clean-credentials.js",
    "linkedin:login": "node scripts/linkedin-login.js",
    "linkedin:test-scrape": "node scripts/test-linkedin-scrape.js",
    "monster:test-scrape": "node scripts/test-monster-scrape.js",
    "dice:test-scrape": "node scripts/test-dice-scrape.js",
    "indeed:login": "node scripts/indeed-login.js",
    "monster:warm": "node scripts/warm-monster.mjs",
    "indeed:test-scrape": "node scripts/test-indeed-scrape.js",
    "glassdoor:test-scrape": "node scripts/test-glassdoor-scrape.js",
    "techfetch:test-scrape": "node scripts/test-techfetch-scrape.js",
    "test": "node --test 'test/**/*.test.js'",
    "setup": "node server.js --setup"
  },
  "keywords": [
    "job-scraper",
    "monster",
    "dice",
    "techfetch",
    "linkedin",
    "glassdoor",
    "indeed",
    "api",
    "web-scraping"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cheerio": "^1.0.0-rc.12",
    "cloakbrowser": "^0.3.28",
    "crawlee": "^3.7.0",
    "express": "^4.18.2",
    "jsdom": "^23.0.1",
    "mmdb-lib": "^3.0.2",
    "node-tls-client": "^2.1.0",
    "playwright": "^1.40.0",
    "playwright-extra": "^4.3.6",
    "prom-client": "^15.1.3",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "undici": "^8.5.0",
    "zod": "^3.23.8"
  }
}
